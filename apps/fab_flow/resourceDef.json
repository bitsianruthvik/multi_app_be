  "fab_project_plans": {
    "table": "fab_project_plans",
    "alias": "fpp",
    "writeFields": ["project_code","project_name","client_name","site_location","plan_name","plan_revision","status","source","notes","company_id","created_by","calendar_id","planned_start_date","target_end_date","scheduling_mode"],
    "fields": {
      "id":                "fpp.id",
      "projectCode":       "fpp.project_code",
      "projectName":       "fpp.project_name",
      "clientName":        "fpp.client_name",
      "siteLocation":      "fpp.site_location",
      "planName":          "fpp.plan_name",
      "planRevision":      "fpp.plan_revision",
      "status":            "fpp.status",
      "source":            "fpp.source",
      "notes":             "fpp.notes",
      "companyId":         "fpp.company_id",
      "createdBy":         "fpp.created_by",
      "approvedBy":        "fpp.approved_by",
      "approvedAt":        "fpp.approved_at",
      "calendarId":        "fpp.calendar_id",
      "plannedStartDate":  "fpp.planned_start_date",
      "targetEndDate":     "fpp.target_end_date",
      "schedulingMode":    "fpp.scheduling_mode",
      "createdAt":         "fpp.created_at",
      "updatedAt":         "fpp.updated_at",
      "createdByName":     "ucb.name",
      "approvedByName":    "uab.name"
    },
    "fieldTypes": {
      "id":                "integer",
      "projectCode":       "string",
      "projectName":       "string",
      "clientName":        "string",
      "siteLocation":      "string",
      "planName":          "string",
      "planRevision":      "string",
      "status":            "string",
      "source":            "string",
      "notes":             "text",
      "companyId":         "integer",
      "createdBy":         "integer",
      "approvedBy":        "integer",
      "approvedAt":        "datetime",
      "calendarId":        "integer",
      "plannedStartDate":  "string",
      "targetEndDate":     "string",
      "schedulingMode":    "string",
      "createdAt":         "datetime",
      "updatedAt":         "datetime",
      "createdByName":     "string",
      "approvedByName":    "string"
    },
    "aliases": {
      "projectCode":       ["project code","project id","project ref","job code"],
      "projectName":       ["project name","project title","job name"],
      "clientName":        ["client","client name","customer"],
      "planName":          ["plan name","plan title","fabrication plan"],
      "planRevision":      ["revision","plan revision","rev","version"],
      "status":            ["status","plan status","state"],
      "createdByName":     ["created by","author","plan owner","raised by"],
      "approvedByName":    ["approved by","approver","sign off"]
    },
    "relations": {
      "createdByUser": {
        "table": "users",
        "alias": "ucb",
        "on":    "fpp.created_by = ucb.id",
        "fields": ["createdByName"]
      },
      "approvedByUser": {
        "table": "users",
        "alias": "uab",
        "on":    "fpp.approved_by = uab.id",
        "fields": ["approvedByName"]
      }
    }
  },

