# Copy this file to .env and fill in real values. Never commit .env itself.

NODE_ENV=production
PORT=4000

# Database — for a managed MySQL-compatible host (TiDB Cloud, PlanetScale, Aiven),
# set DB_SSL=true. Leave DB_SSL unset for local MySQL.
DB_HOST=
DB_PORT=4000
# ^ Note: TiDB Cloud's MySQL-protocol port also happens to be 4000 — unrelated
# to this app's own PORT above. Use whatever port your DB host gives you.
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=true
DB_POOL_SIZE=10

# Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of additional frontend origins allowed to call this API
# (the deployed Vercel URL goes here once you have it).
CORS_ORIGINS=

# Optional — job queue falls back to inline processing if unset.
# REDIS_URL=

# Optional — used by internal worker-to-worker calls, not required for basic hosting.
# WORKER_SERVICE_TOKEN=
